SERVER_NAME=192.168.1.77

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
ANYTHINGLLM_PORT=3001
OPENWEBUI_PORT=3000
AI_NGINX_PORT=8088
ANYTHINGLLM_NGINX_PORT=8089

AI_PROJECT_DIR=/opt/emex-ai-assistant
TZ=Asia/Almaty

# Смените ключ перед рабочим запуском: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# UID/GID пользователя на Ubuntu-сервере. Обычно 1000:1000.
UID=1000
GID=1000

# Модели по умолчанию для первичной загрузки.
PRIMARY_CHAT_MODEL=qwen2.5:7b-instruct
FALLBACK_CHAT_MODEL=llama3.2
EMBEDDING_MODEL=nomic-embed-text
